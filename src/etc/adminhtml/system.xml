<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="security" translate="label" sortOrder="200">
            <label>Security</label>
        </tab>
        <section id="adminpasskey" translate="label" type="text" sortOrder="510" showInDefault="1"
                 showInWebsite="0" showInStore="0">
            <class>separator-top</class>
            <label>Admin Passkeys (WebAuthn)</label>
            <tab>security</tab>
            <resource>MageMate_AdminPasskey::config</resource>
            <group id="general" translate="label" type="text" sortOrder="10" showInDefault="1"
                   showInWebsite="0" showInStore="0">
                <label>General</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Enabled</label>
                    <comment>Enable admin passkey (WebAuthn) registration and login.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="force_setup" translate="label comment" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Force Passkey Setup</label>
                    <comment>Require admins with no passkey to register one after signing in.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="disallow_password_login" translate="label comment" type="select" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Disallow Password Login</label>
                    <comment>Block password login for admins who already have an active passkey.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="passkey_max_validity_days" translate="label comment" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Passkey Max Validity (days)</label>
                    <comment>Number of days a passkey stays valid. 0 = never expires.</comment>
                    <validate>validate-digits validate-zero-or-greater</validate>
                </field>
                <field id="require_user_verification" translate="label comment" type="select" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Require User Verification</label>
                    <comment>Require biometric/PIN user verification during passkey ceremonies.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="satisfies_2fa" translate="label comment" type="select" sortOrder="60"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Passkey Satisfies 2FA</label>
                    <comment>Treat a successful passkey login as a satisfied two-factor authentication.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="rp_id" translate="label comment" type="text" sortOrder="70"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Relying Party ID (override)</label>
                    <comment>Optional. Leave blank to derive from the admin base URL host.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="rp_name" translate="label comment" type="text" sortOrder="80"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Relying Party Name (override)</label>
                    <comment>Optional. Leave blank to derive from the store name.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>
        </section>
    </system>
</config>
